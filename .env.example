# app/server
NODE_ENV=development
PORT=8080
BASE_PATH=
LOG_LEVEL=info
BOOTSTRAP_ALLOW_PROD=0 # set to 1 only when intentionally bootstrapping production
VITE_POSTHOG_KEY= # optional analytics
VITE_POSTHOG_HOST=https://us.i.posthog.com

# database
DATABASE_URL=

# Clerk auth
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL= # production/custom-domain Clerk proxy URL

# Stripe
# Stripe is currently loaded through the Replit connector values below.

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# Replit-specific values
REPLIT_CONNECTORS_HOSTNAME= # required for Replit Stripe connector flows
REPL_IDENTITY= # Replit workspace connector token
WEB_REPL_RENEWAL= # Replit deployment connector token
REPLIT_DEPLOYMENT= # set by Replit deployments
REPLIT_DOMAINS= # used to build Stripe webhook URL in Replit
REPL_ID= # enables Replit Vite dev plugins
